// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @db.Uuid
  email     String   @unique

  @@ignore
}

model Profile {
  id        String   @id @db.Uuid
  fullName  String?  @map("full_name")
  role      Role     @relation(fields: [roleId], references: [id])
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([roleId])
  @@map("profiles")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  profiles    Profile[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action      String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model ApiKey {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   // Friendly name for the key
  apiName      String   @map("api_name") // Which API: jobsuche, etc.
  encryptedKey String   @map("encrypted_key") // Encrypted API key value
  status       String   @default("active") // active, inactive, revoked
  createdById  String   @map("created_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastUsed     DateTime? @map("last_used") @db.Timestamptz(6)
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz(6)
  metadata     Json     @default("{}") // Additional configuration per API

  @@index([apiName])
  @@index([status])
  @@index([createdById])
  @@unique([createdById, apiName, name])
  @@map("api_keys")
}
